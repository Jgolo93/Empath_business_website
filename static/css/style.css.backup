    width: 22.3%;
    position: relative;
}
.zf-tempFrmWrapper.zf-phone span input[type="text"] {
	width: 100%;
}
.zfMultiColGrid .zf-tempFrmWrapper.zf-phone .zf-symbols {
    display: none;
}
